{
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild": "npx expo prebuild",
    "prebuild:clean": "npx expo prebuild --clean",
    "ios": "npx expo prebuild --clean && expo run:ios --configuration Release",
    "ios:dev": "APP_VARIANT=development npx expo prebuild --clean && APP_VARIANT=development expo run:ios",
    "ios:preview": "APP_VARIANT=preview npx expo prebuild --clean && APP_VARIANT=preview expo run:ios --configuration Release",
    "web": "expo start --web",
    "eject": "expo eject",
    "dev": "APP_VARIANT=development expo start",
    "lint": "eslint . && tsc",
    "test": "jest --silent",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --silent",
    "test:coverage-summary": "jest --coverage --coverageReporters=text-summary --silent",
    "install:ipa": "scripts/install-ipa.sh",
    "postinstall": "patch-package",
    "maestro:seed": "PATH=\"$PATH\":\"$HOME/.maestro/bin\" maestro test .maestro/seed.yaml --env APP_ID=com.wyne.scorepad --test-output-dir .maestro/runs",
    "maestro:seed:dev": "PATH=\"$PATH\":\"$HOME/.maestro/bin\" maestro test .maestro/seed.yaml --env APP_ID=com.wyne.scorepad.dev --test-output-dir .maestro/runs",
    "maestro": "PATH=\"$PATH\":\"$HOME/.maestro/bin\" maestro test .maestro/record.yaml --env APP_ID=com.wyne.scorepad --test-output-dir .maestro/runs",
    "maestro:dev": "PATH=\"$PATH\":\"$HOME/.maestro/bin\" maestro test .maestro/record.yaml --env APP_ID=com.wyne.scorepad.dev --test-output-dir .maestro/runs",
    "maestro:all": "npm run maestro:seed && npm run maestro",
    "maestro:record": "PATH=\"$PATH\":\"$HOME/.maestro/bin\" maestro record --local .maestro/record.yaml --env APP_ID=com.wyne.scorepad",
    "e2e": "wdio run e2e/wdio.config.ts",
    "e2e:record": "e2e/scripts/record.sh"
  },
